# =====================================================
# 答辩演示环境配置
# 换教室 / 换热点时，只需修改下方 IP，然后重启 npm run dev
# =====================================================

# 推理服务（server.py）所在电脑的局域网 IP 地址
VITE_AI_SERVER_HOST=192.168.0.168

# 推理服务端口（默认 8000，通常不需要改）
VITE_AI_SERVER_PORT=8000

# 是否启用同源 MJPEG 代理（true = 由 FastAPI 转发摄像头流，false = 浏览器直连摄像头）
# 直连模式延迟更低，推荐演示时使用 false；跨网段或跨域时改为 true 并确保 server.py 已挂载 cam_stream_proxy
VITE_CAM_STREAM_PROXY=false
